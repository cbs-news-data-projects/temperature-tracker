# Environment variables for this project.
#
# Setup:  cp .env.example .env  then edit .env with real values.
# The .env file is git-ignored. config.py loads it automatically on import,
# so anything here is available via os.getenv("NAME") in notebooks and scripts.

# --- Project settings ---
OUTPUT_DIR=data/processed      # where quick_export_for_web() writes
RANDOM_SEED=42                 # set for reproducible sampling/shuffles

# --- Secrets (uncomment and fill in the ones you need) ---
# DATA_API_KEY=                # generic source API key (used by scripts/fetch.py)
# DATAWRAPPER_API_TOKEN=       # for the datawrapper python client
# DATABASE_URL=                # e.g. postgresql://user:pass@host:5432/dbname
